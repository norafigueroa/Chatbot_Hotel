# Copiá este archivo a `.env.local` y colocá tus valores reales.
# `.env.local` está en .gitignore y NUNCA se sube a GitHub.
#
# ============================================================
# BACKEND (funciones serverless en /api) — llaves SECRETAS.
# Estas NO llevan prefijo VITE_ y NUNCA llegan al navegador.
# ============================================================

# Proveedor de IA activo: "openrouter" (prototipo) o "anthropic" (Claude, final).
LLM_PROVIDER=openrouter

# --- OpenRouter (prototipo) --- https://openrouter.ai/ -> Keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Opcional: cadena de modelos de respaldo (separados por coma).
# OPENROUTER_MODELS=nvidia/nemotron-3-ultra-550b-a55b:free,poolside/laguna-m.1:free

# --- Anthropic / Claude (entregable final) --- https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-5

# --- Supabase (base de datos: FAQs + leads) --- Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # SECRETA (service_role), solo servidor

# --- Resend (envío de leads por correo al hotel) --- https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# LEAD_EMAIL_TO=reserve@islachiquita.com
# LEAD_EMAIL_FROM=Chatbot Isla Chiquita <chatbot@islachiquita.com>

# ============================================================
# FRONTEND (Vite) — variables públicas (visibles en el navegador).
# ============================================================
# URL base del backend. En local con `vercel dev` dejalo vacío (usa /api).
# VITE_API_BASE=
